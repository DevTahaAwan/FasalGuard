# FasalGuard Environment Variables
# Copy this file to .env.local and populate all values before running the app.
# NEVER commit .env.local to version control.

# ─── Supabase (public — safe to expose in browser) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Supabase (server-only — NEVER prefix with NEXT_PUBLIC_) ─────────────────
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── HuggingFace Inference API (server-only) ─────────────────────────────────
# Model: linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification
HUGGINGFACE_API_TOKEN=your-huggingface-api

# ─── Google Gemini API (server-only) ─────────────────────────────────────────
# Used for Stage 2: advisory text generation (Gemini 1.5 Flash)
GEMINI_API_KEY=gemini-api-here

# ─── Google Cloud TTS API (server-only) ──────────────────────────────────────
# Used for TTS Tier 2 fallback when Web Speech API lacks Urdu voice
GOOGLE_CLOUD_TTS_API_KEY=your-gcloud-tts-key

# ─── Upstash Redis (server-only — rate limiting) ─────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ─── Sentry Error Tracking (used both client and server) ─────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ─── App Environment ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=development
